# Normalize line endings on checkout/checkin.
* text=auto eol=lf

# GitHub language stats — the Electron UI ships generated TS/JS that
# would otherwise dominate the repo's language breakdown. Mark
# vendored / generated paths so GitHub reports ember as a C++ project.
ui/dist/**          linguist-generated=true
ui/build/**         linguist-generated=true
ui/node_modules/**  linguist-vendored=true
docs/**             linguist-documentation=true
tests/golden/**     linguist-generated=true

# Binary fixtures — don't try to diff these.
tests/fixtures/**   binary
*.teef              binary
