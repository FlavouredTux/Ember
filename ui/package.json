{
  "name": "ember-ui",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/FlavouredTux/Ember",
  "author": {
    "name": "FlavouredTux",
    "email": "noreply@github.com"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c magenta,cyan \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:hyprland": "concurrently -k -n vite,electron -c magenta,cyan \"vite\" \"wait-on http://localhost:5173 && env ELECTRON_FORCE_DEVICE_SCALE_FACTOR=${EMBER_SCALE_FACTOR:-1.5} electron .\"",
    "dev:wayland": "concurrently -k -n vite,electron -c magenta,cyan \"vite\" \"wait-on http://localhost:5173 && env GDK_BACKEND=wayland ELECTRON_OZONE_PLATFORM=wayland electron .\"",
    "dev:wayland:software": "concurrently -k -n vite,electron -c magenta,cyan \"vite\" \"wait-on http://localhost:5173 && env GDK_BACKEND=wayland ELECTRON_OZONE_PLATFORM=wayland EMBER_DISABLE_GPU=1 electron .\"",
    "build": "vite build",
    "start": "electron .",
    "start:hyprland": "env ELECTRON_FORCE_DEVICE_SCALE_FACTOR=${EMBER_SCALE_FACTOR:-1.5} electron .",
    "start:wayland": "env GDK_BACKEND=wayland ELECTRON_OZONE_PLATFORM=wayland electron .",
    "start:wayland:software": "env GDK_BACKEND=wayland ELECTRON_OZONE_PLATFORM=wayland EMBER_DISABLE_GPU=1 electron .",
    "package": "vite build && electron-builder",
    "package:linux": "vite build && electron-builder --linux",
    "package:mac": "vite build && electron-builder --mac",
    "package:win": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "ai.ember.app",
    "productName": "Ember",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../scripts",
        "to": "scripts"
      },
      {
        "from": "../plugins",
        "to": "plugins"
      },
      {
        "from": "../agent/dist",
        "to": "agent/dist"
      },
      {
        "from": "../agent/node_modules",
        "to": "agent/node_modules",
        "filter": [
          "**/*",
          "!**/{*.md,*.txt,LICENSE*,*.map}",
          "!**/{test,tests,docs,examples}/**"
        ]
      },
      {
        "from": "../agent/package.json",
        "to": "agent/package.json"
      }
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "../build/cli/ember",
          "to": "cli/ember"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "../build/cli/ember",
          "to": "cli/ember"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "../build/cli/ember.exe",
          "to": "cli/ember.exe"
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.139",
    "@xhayper/discord-rpc": "^1.3.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.95.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
