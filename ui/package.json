{
  "name": "ember-ui",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/FlavouredTux/Ember",
  "author": {
    "name": "FlavouredTux",
    "email": "noreply@github.com"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c magenta,cyan \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "package": "vite build && electron-builder",
    "package:linux": "vite build && electron-builder --linux",
    "package:mac": "vite build && electron-builder --mac",
    "package:win": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "ai.ember.app",
    "productName": "Ember",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../scripts",
        "to": "scripts"
      },
      {
        "from": "../plugins",
        "to": "plugins"
      }
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "../build/cli/ember",
          "to": "cli/ember"
        }
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "../build/cli/ember",
          "to": "cli/ember"
        }
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png",
      "extraResources": [
        {
          "from": "../build/cli/ember.exe",
          "to": "cli/ember.exe"
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@xhayper/discord-rpc": "^1.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}
